# Per-role SSH keys are generated locally per clone and must never be
# committed. Keep the role directories themselves so they exist on clone.
infra/keys/architect/*
infra/keys/planner/*
infra/keys/coder/*
infra/keys/auditor/*
infra/keys/human/*
!infra/keys/*/.gitkeep

# Per-pair credentials emitted by commission-pair.sh.
.pairs/.pair-*.env

# Per-host overrides.
.env

# Substrate identity sentinel — generated on first setup, paired with a
# matching label on the claude-state-architect docker volume. Per-clone,
# never committed. See methodology/deployment-docker.md §3.5.
.substrate-id

# Editor / OS noise.
*.log
*.swp
.DS_Store

# Node — only the coder-daemon image installs deps (inside the container).
node_modules/

# s009: generated by infra/scripts/render-dockerfile.sh from the role's
# static template + the selected platform YAMLs. Per-host artifact, never
# committed.
infra/*/Dockerfile.generated

# s009: generated by infra/scripts/render-device-override.sh when
# --device=<host-path> is supplied at setup. Per-host artifact, never
# committed. The path is at the repo root so docker compose autoload
# picks it up — every existing call site (commission-pair.sh, audit.sh,
# verify.sh, the substrate end-to-end test) gets device wiring without
# a code change.
docker-compose.override.yml

# s009: substrate state directory. Setup writes platforms.txt and
# devices.txt here; the architect compose service mounts the directory
# read-only at /substrate. Per-clone, regenerated by every setup run.
.substrate-state/

# s010: per-remote-host SSH keys, generated at registration time by
# bootstrap-remote-host.sh. The directory itself stays tracked via the
# top-level .gitkeep; per-host subdirectories (e.g. tdongle-pi/) are not.
infra/keys/remote-hosts/*/*
!infra/keys/remote-hosts/.gitkeep

# s010: cumulative known-hosts file for registered remote hosts. Already
# covered by the .substrate-state/ rule above; called out for clarity.
.substrate-state/known-hosts
